# 复制为 .env 后按需填写；勿将 .env 提交到版本库。

# ============================================
# 基本配置
# ============================================

# 运行环境：development | staging | production
APP_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 日志格式：text（本地开发）| json（生产环境，便于日志采集）
LOG_FORMAT=text

# ============================================
# HTTP 服务
# ============================================

# HTTP 监听地址
HTTP_ADDR=:8080

# ============================================
# 数据库
# ============================================

# PostgreSQL 连接字符串
POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/ai_interview?sslmode=disable

# Redis 配置
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# 消息队列
# ============================================

# 消息队列连接地址（Kafka / RabbitMQ 等）
MQ_BROKER_URL=

# 面试完成事件主题
MQ_TOPIC_INTERVIEW_FINISHED=interview_finished

# ============================================
# 对象存储（S3 兼容）
# ============================================

# S3 或 MinIO 端点
S3_ENDPOINT=

# S3 访问密钥
S3_ACCESS_KEY=
S3_SECRET_KEY=

# S3 存储桶和区域
S3_BUCKET=
S3_REGION=us-east-1

# 是否使用 SSL
S3_USE_SSL=true

# ============================================
# JWT 认证
# ============================================

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# JWT 签发者
JWT_ISSUER=ai_interview

# JWT 访问令牌过期时间（分钟）
JWT_ACCESS_EXP_MIN=60

# ============================================
# LLM 模型提供商
# ============================================

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 豆包（Doubao）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=

# 千问（Qwen）- 用于 ASR/TTS 和 Agent
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Claude
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ============================================
# Agent 模型配置
# ============================================

# Supervisor Agent 模型
SUPERVISOR=qwen-plus

# Question Selector Agent 模型
SELECTOR=qwen-plus

# Stage Manager Agent 模型
MANAGER=qwen-plus

# Response Analyzer Agent 模型
ANALYZER=qwen-plus

# Evaluator Agent 模型
EVALUATOR=qwen-plus

# ============================================
# ASR/TTS 模型配置
# ============================================

# ASR（语音识别）模型
# 可选：qwen3-asr-flash-realtime（稳定版）
ASR_MODEL=qwen3-asr-flash-realtime

# TTS（语音合成）模型
# 可选：qwen-tts-flash-realtime
TTS_MODEL=qwen-tts-flash-realtime

# TTS 音色
# 可选：zhifeng_emo（知风）、zhiyan_emo（知言）、zhiyu_emo（知语）
TTS_VOICE=zhifeng_emo

# ============================================
# Redis TTL 配置
# ============================================

# 简历缓存过期时间（Go time.ParseDuration 格式，例如：168h = 7天）
RESUME_REDIS_TTL=168h

# 面试状态过期时间（例如：48h = 2天）
INTERVIEW_STATE_TTL=48h
