# 复制为 .env 后按需填写；勿将 .env 提交到版本库。

# ============================================
# 基本配置
# ============================================

# 运行环境：development | staging | production
APP_ENV=development

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# 日志格式：text（本地开发）| json（生产环境，便于日志采集）
LOG_FORMAT=text

# ============================================
# HTTP 服务
# ============================================

# HTTP 监听地址
HTTP_ADDR=:8080

# ============================================
# 数据库
# ============================================

# PostgreSQL 连接字符串（与 docker-compose 账号/库名一致）
POSTGRES_DSN=postgres://aiinterview:aiinterview123@127.0.0.1:5432/aiinterview?sslmode=disable

# PostgreSQL 连接池（可选，有合理默认值）
PG_MAX_OPEN_CONNS=25       # 最大打开连接数
PG_MAX_IDLE_CONNS=5        # 最大空闲连接数
PG_CONN_MAX_LIFETIME=30m   # 连接最大存活时间
PG_CONN_MAX_IDLE_TIME=5m   # 连接最大空闲时间

# Redis 配置（密码与 docker-compose 一致）
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=aiinterview123
REDIS_DB=0

# Redis 连接池（可选，有合理默认值）
REDIS_POOL_SIZE=10          # 最大连接数
REDIS_MIN_IDLE_CONNS=2      # 最小空闲连接
REDIS_DIAL_TIMEOUT=5s       # 建连超时
REDIS_READ_TIMEOUT=3s       # 读超时
REDIS_WRITE_TIMEOUT=3s      # 写超时

# ============================================
# 消息队列
# ============================================

# 消息队列连接地址（RabbitMQ，与 docker-compose 一致）。
# 留空则跳过 MQ，面试报告异步生成（ReportWorker）将不启动。
MQ_BROKER_URL=amqp://aiinterview:aiinterview123@127.0.0.1:5672/

# 面试完成事件主题
MQ_TOPIC_INTERVIEW_FINISHED=interview_finished

# ============================================
# 对象存储（S3 兼容）
# ============================================

# S3 或 MinIO 端点（与 docker-compose 的 MinIO 一致）
S3_ENDPOINT=127.0.0.1:9000

# S3 访问密钥（与 docker-compose 的 MinIO 一致）
S3_ACCESS_KEY=aiinterview
S3_SECRET_KEY=aiinterview123

# S3 存储桶和区域
S3_BUCKET=ai-interview
S3_REGION=us-east-1

# 是否使用 SSL（本地 MinIO 未启用 TLS，需为 false）
S3_USE_SSL=false

# ============================================
# JWT 认证
# ============================================

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# JWT 签发者
JWT_ISSUER=ai_interview

# JWT 访问令牌过期时间（分钟）
JWT_ACCESS_EXP_MIN=60

# ============================================
# LLM 模型提供商
# ============================================

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 豆包（Doubao）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=

# 千问（Qwen）- 用于 ASR/TTS 和 Agent
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Claude
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ============================================
# Agent 模型配置
# ============================================

# Supervisor Agent 模型
SUPERVISOR=qwen-plus

# Question Selector Agent 模型
SELECTOR=qwen-plus

# Stage Manager Agent 模型
MANAGER=qwen-plus

# Response Analyzer Agent 模型
ANALYZER=qwen-plus

# Evaluator Agent 模型
EVALUATOR=qwen-plus

# ============================================
# ASR/TTS 模型配置
# ============================================

# ASR（语音识别）模型
# 可选：qwen3-asr-flash-realtime（稳定版）
ASR_MODEL=qwen3-asr-flash-realtime

# TTS（语音合成）模型
# 可选：qwen-tts-flash-realtime
TTS_MODEL=qwen-tts-flash-realtime

# TTS 音色
# 可选：zhifeng_emo（知风）、zhiyan_emo（知言）、zhiyu_emo（知语）
TTS_VOICE=zhifeng_emo

# ============================================
# Redis TTL 配置
# ============================================

# 简历缓存过期时间（Go time.ParseDuration 格式，例如：168h = 7天）
RESUME_REDIS_TTL=168h

# 面试状态过期时间（例如：48h = 2天）
INTERVIEW_STATE_TTL=48h

# ============================================
# Milvus 向量数据库
# ============================================

# 是否启用 RAG（向量/关键词检索）。
# false（默认）：出题走 LLM wiki（读本地 SKILL.md），不连 Milvus/ES，启动轻量。
# true：连接 Milvus + Elasticsearch，需先启动对应服务。
RAG_ENABLED=false

# Milvus gRPC 地址（host:port）
MILVUS_ADDR=127.0.0.1:19530

# 题库向量集合名
MILVUS_COLLECTION=bank_questions_vec

# ============================================
# Elasticsearch
# ============================================

# 节点地址列表（逗号分隔，支持多节点）
ES_ADDRS=http://127.0.0.1:9200

# ES 认证（无密码留空）
ES_USERNAME=
ES_PASSWORD=

# 题库 ES 索引名
ES_INDEX=bank_questions

# ============================================
# Ollama（本地模型，可选）
# ============================================

# Ollama 服务地址（不启用本地模型可留空）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# embedding 模型（本地用）
OLLAMA_EMBED_MODEL=nomic-embed-text

# chat 模型（本地用，也可换成 llama3.3 等）
OLLAMA_CHAT_MODEL=qwen3:8b
