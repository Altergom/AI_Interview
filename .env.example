# 复制为 .env 后按需填写；勿将 .env 提交到版本库。

# 运行环境：development | staging | production
APP_ENV=development
LOG_LEVEL=info
# 日志输出：text（本地）| json（容器、便于接入采集侧）
LOG_FORMAT=text
# 仅本地无依赖调试：1 时 /ready 不检查数据库与 Redis
READINESS_SKIP_ALL=0

# HTTP 监听地址（Hertz 等）
HTTP_ADDR=:8080

# PostgreSQL（示例为本地开发）
POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/ai_interview?sslmode=disable

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# 消息队列（Kafka / RabbitMQ 等，按选型填写连接串）
MQ_BROKER_URL=
MQ_TOPIC_INTERVIEW_FINISHED=interview_finished

# S3 或 MinIO 等兼容 S3 API
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_USE_SSL=true

# JWT
JWT_SECRET=
JWT_ISSUER=ai_interview
JWT_ACCESS_EXP_MIN=60

# LLM（Eino 接入时选用）
OPENAI_API_KEY=
OPENAI_BASE_URL=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=

# Redis TTL（Go time.ParseDuration，例如 168h、48h）
RESUME_REDIS_TTL=168h
INTERVIEW_STATE_TTL=48h
